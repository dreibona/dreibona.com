---
/* ─────────────────────────────────────────────────────────────────────────── */
/* Component for rendering paginated post list pages (Lab and Tags)            */
/* Displays post lists with optional tag filtering and pagination controls     */
/* ─────────────────────────────────────────────────────────────────────────── */
import Post from '@components/Post.astro';
import PostPagination from '@components/PostPagination.astro';

import { useTranslations } from '@/i18n/translations';
import { getLocalizedPageUrl } from '@/i18n/utils';
import type { PostEntry } from '@/utils/routes';
import type { Locale } from '@/i18n/locales';

interface Props {
  title?: string;
  tag?: string;
  posts: PostEntry[];
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { title, tag, posts, currentPage, totalPages, baseUrl } = Astro.props;
const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
const showTotal = !!tag;
const showBackLink = !!tag;
---

<div class='prose'>
  {
    tag ? (
      <>
        Tag: <span class='tag'>#{tag}</span>
      </>
    ) : (
      title || t('lab.title')
    )
  }

  {
    showTotal && (
      <p>
        {posts.length} {posts.length === 1 ? t('lab.postCount.one') : t('lab.postCount.many')}
      </p>
    )
  }
  {
    showBackLink && (
      <a href={getLocalizedPageUrl('/lab/', locale)} class='back-link'>
        {t('lab.backToLab')}
      </a>
    )
  }
</div>

<ul class='post-list' role='list'>
  {
    posts.map((post) => (
      <li>
        <Post post={post} variant='list' />
      </li>
    ))
  }
</ul>

<PostPagination currentPage={currentPage} totalPages={totalPages} baseUrl={baseUrl} />
