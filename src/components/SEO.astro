---
/* ─────────────────────────────────────────────────────────────────────────── */
/* Component for injecting SEO metadata and structured data into the head      */
/* Renders meta tags for Open Graph, Twitter, hreflang, and JSON-LD schema    */
/* ─────────────────────────────────────────────────────────────────────────── */
import { siteConfig } from '@config/site';
import { LOCALES, LOCALE_PATHS, DEFAULT_LOCALE, OG_LOCALE_MAP } from '@/i18n/locales';
import { getCanonicalPath } from '@/i18n/utils';

interface Props {
  headMeta: ReturnType<typeof import('@config/seo').getMeta>;
  schemaMarkup: string;
}

const { headMeta, schemaMarkup } = Astro.props;

const {
  pageTitle,
  description,
  author,
  image,
  baseSite,
  loc,
  locale,
  type,
  robot,
  currentUrl,
  publishDate,
  modifiedDate,
} = headMeta;

/* Locale-aware RSS feed URL */
const rssHref =
  locale === DEFAULT_LOCALE
    ? `${Astro.site}rss.xml`
    : `${Astro.site}${LOCALE_PATHS[locale]}/rss.xml`;

/* Generate hreflang alternate URLs for all locales */
const canonicalPath = getCanonicalPath(new URL(currentUrl).pathname);
const alternates = LOCALES.map((l) => {
  const locPath = LOCALE_PATHS[l];
  const href = locPath
    ? new URL(`/${locPath}${canonicalPath}`, baseSite).toString()
    : new URL(canonicalPath, baseSite).toString();
  return { locale: l, href };
});
const xDefaultHref = new URL(canonicalPath, baseSite).toString();

/* Resolved absolute image URL — used in OG and Twitter meta tags */
const imageUrl = new URL(image.url, baseSite).toString();
---

<meta charset='utf-8' />
<meta name='viewport' content='width=device-width, initial-scale=1, viewport-fit=cover' />

<title>{pageTitle}</title>

<meta name='color-scheme' content='light dark' />
<meta name='theme-color' content='#ffffff' media='(prefers-color-scheme: light)' />
<meta name='theme-color' content='#111111' media='(prefers-color-scheme: dark)' />

<meta name='description' content={description} />
<meta name='author' content={author} />
<meta name='robots' content={robot} />
<link rel='canonical' href={currentUrl} />

{alternates.map(({ locale: l, href }) => <link rel='alternate' hreflang={l} href={href} />)}
<link rel='alternate' hreflang='x-default' href={xDefaultHref} />

<link rel='alternate' type='application/rss+xml' title={siteConfig.name} href={rssHref} />
<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
<link rel='apple-touch-icon' href='/apple-touch-icon.png' />

<meta property='og:type' content={type} />
<meta property='og:url' content={currentUrl} />
<meta property='og:title' content={pageTitle} />
<meta property='og:description' content={description} />
<meta property='og:image' content={imageUrl} />
<meta property='og:image:alt' content={image.alt} />
<meta property='og:image:width' content='1200' />
<meta property='og:image:height' content='630' />
<meta property='og:site_name' content={siteConfig.name} />
<meta property='og:locale' content={loc} />
{
  LOCALES.filter((l) => l !== locale).map((l) => (
    <meta property='og:locale:alternate' content={OG_LOCALE_MAP[l]} />
  ))
}

{
  type === 'article' && publishDate && (
    <meta property='article:published_time' content={publishDate} />
  )
}
{
  type === 'article' && modifiedDate && (
    <meta property='article:modified_time' content={modifiedDate} />
  )
}

<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:title' content={pageTitle} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={imageUrl} />
<meta name='twitter:image:alt' content={image.alt} />

<script is:inline type='application/ld+json' set:html={schemaMarkup} />
