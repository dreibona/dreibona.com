---
import { nav } from '../config/config';
const path = Astro.url.pathname;
---

<nav>
  <span>
    <a href="/" aria-label="home page">db</a>
  </span>
  <ul>
    {
      nav.map((slug) => {
        const label = slug.page.replaceAll('/', '').toUpperCase();
        const isActive = path === slug.page;
        return (
          <li>
            <a
              href={slug.page}
              aria-current={isActive ? 'page' : undefined}
              aria-label={slug.page + ' page'}
              class="nav-link"
            >
              {label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
