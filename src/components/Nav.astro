---
/**
 * Nav Component
 * Renders the primary navigation bar. It dynamically generates links based on the
 * site configuration and highlights the active route.
 */
import type { SiteConfig } from '@config/site';
import Limiter from '@components/Limiter.astro';

interface Props {
  nav: SiteConfig['nav'];
}

const { nav } = Astro.props;
const { home, links } = nav;
/**
 * Path Detection:
 * Used to determine the 'active' state of navigation links by comparing
 * the current URL path with the link's destination.
 */
const path = Astro.url.pathname;
---

<nav data-nosnippet>
  <Limiter>
    <div class='nav-container'>
      <span>
        <a href={home.href} aria-label='home page'>{home.label}</a>
      </span>
      <ul>
        {
          links.map(({ label, href }) => {
            const isActive = path === href;
            return (
              <li>
                <a
                  href={href}
                  class:list={['nav-link', { active: isActive }]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label.toUpperCase()}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </Limiter>
</nav>

<style>
  nav {
    background-color: var(--color-primary);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
  }

  span {
    display: flex;
  }

  span a {
    display: flex;
    align-items: center;
    min-block-size: var(--space-lg);
    padding-block: var(--space-sm);
    font-weight: 700;
  }

  ul {
    display: flex;
    align-items: stretch;
    list-style: none;
    padding: 0;
  }

  li {
    display: flex;
  }

  .nav-link {
    display: flex;
    align-items: center;
    min-block-size: var(--space-lg);
    padding-inline: var(--space-md);
    padding-block: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 700;
    transition: background-color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.active {
    background-color: var(--color-black);
    color: var(--color-white);
  }
</style>
