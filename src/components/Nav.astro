---
/* ─────────────────────────────────────────────────────────────────────────── */
/* Main navigation component for the site header                               */
/* Displays home link and navigation menu with active page indicator           */
/* ─────────────────────────────────────────────────────────────────────────── */
import type { NavItem } from '@config/site';

interface Props {
  home: NavItem;
  links: NavItem[];
}

const { home, links } = Astro.props;
const path = Astro.url.pathname;
---

<nav>
  <div class='limiter'>
    <div class='nav-container'>
      <a href={home.href} class='nav-home' aria-label='Home'>{home.label}</a>
      <ul role='list' class='nav-links'>
        {
          links.map(({ label, href }) => {
            const isActive = path === href;
            return (
              <li>
                <a
                  href={href}
                  class:list={['nav-link', { active: isActive }]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label.toUpperCase()}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</nav>
