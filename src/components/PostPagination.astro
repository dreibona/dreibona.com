---
/* ─────────────────────────────────────────────────────────────────────────── */
/* Component for rendering pagination navigation                               */
/* Provides previous/next and numbered page links with accessibility support   */
/* ─────────────────────────────────────────────────────────────────────────── */
import { useTranslations } from '@/i18n/translations';
import type { Locale } from '@/i18n/locales';

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);

const base = baseUrl.endsWith('/') ? baseUrl.slice(0, -1) : baseUrl;
const getPageUrl = (page: number) => (page === 1 ? `${base}/` : `${base}/${page}/`);

const pages = Array.from({ length: totalPages }, (_, i) => i + 1);
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;
---

{
  totalPages > 1 && (
    <nav class='pagination' aria-label={t('pagination.label')}>
      <ul role='list'>
        <li>
          <a
            href={hasPrev ? getPageUrl(currentPage - 1) : undefined}
            class:list={['page-link', { disabled: !hasPrev }]}
            aria-disabled={!hasPrev || undefined}
            aria-label={t('pagination.prev')}
            tabindex={!hasPrev ? -1 : undefined}
          >
            <svg
              aria-hidden='true'
              focusable='false'
              width='16'
              height='16'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'
            >
              <path d='m15 18-6-6 6-6' />
            </svg>
          </a>
        </li>

        {pages.map((page) => {
          const isCurrent = page === currentPage;
          return (
            <li>
              <a
                href={getPageUrl(page)}
                class:list={['page-link', { active: isCurrent }]}
                aria-current={isCurrent ? 'page' : undefined}
                aria-label={`${t('pagination.page')} ${page}`}
              >
                {page}
              </a>
            </li>
          );
        })}

        <li>
          <a
            href={hasNext ? getPageUrl(currentPage + 1) : undefined}
            class:list={['page-link', { disabled: !hasNext }]}
            aria-disabled={!hasNext || undefined}
            aria-label={t('pagination.next')}
            tabindex={!hasNext ? -1 : undefined}
          >
            <svg
              aria-hidden='true'
              focusable='false'
              width='16'
              height='16'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2.5'
              stroke-linecap='round'
              stroke-linejoin='round'
            >
              <path d='m9 18 6-6-6-6' />
            </svg>
          </a>
        </li>
      </ul>
    </nav>
  )
}
