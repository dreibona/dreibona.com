---
/* Layout for individual blog post pages */
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import { formatDate } from '@/utils/date';
import type { CollectionEntry } from 'astro:content';

interface Props {
  meta: CollectionEntry<'posts'>['data'];
  readingTime?: string;
}

const { meta, readingTime } = Astro.props;
const date = formatDate(meta.publishDate);
---

<Layout meta={meta}>
  <article>
    <header>
      <h1>{meta.title}</h1>
      <p class='byline'>
        {meta.author} &mdash;
        <time datetime={meta.publishDate.toISOString()}>{date}</time>
        {readingTime && <span> &mdash; {readingTime}</span>}
      </p>

      {
        meta.tags?.length > 0 && (
          <ul class='tags' role='list' aria-label='Post tags'>
            {meta.tags.map((tag: string) => (
              <li>
                <a href={`/lab/tags/${tag}/`}>#{tag}</a>
              </li>
            ))}
          </ul>
        )
      }

      {
        /* Eager loading for hero image to optimize LCP */
        meta.image && (
          <Image
            src={meta.image}
            alt={meta.imageAlt ?? meta.title}
            loading='eager'
            decoding='async'
          />
        )
      }
    </header>

    <div class='prose'>
      <slot />
    </div>
  </article>
</Layout>

<style>
  header {
    margin-block-end: var(--space-lg);
  }

  .byline {
    margin-block-start: var(--space-sm);
    font-size: var(--text-sm);
    opacity: 0.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);

    margin-block-start: var(--space-sm);

    & a {
      font-size: var(--text-sm);
      font-family: var(--font-mono);
      color: var(--color-primary);

      &:hover {
        text-decoration: underline;
      }
    }
  }
</style>
