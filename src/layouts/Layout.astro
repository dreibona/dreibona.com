---
/* ─────────────────────────────────────────────────────────────────────────── */
/* Main site layout including SEO, navigation, and footer                      */
/* Provides base HTML structure with grid layout (header, main, footer)        */
/* Handles font loading, SEO metadata, and structured data generation          */
/* ─────────────────────────────────────────────────────────────────────────── */
import { Font } from 'astro:assets';
import '@styles/global.css';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import SEO from '@components/SEO.astro';
import { getMeta, getSchema } from '@config/seo';
import type { PostMeta } from '@config/seo';
import type { Locale } from '@/i18n/locales';
import { useTranslations } from '@/i18n/translations';
import { getNav } from '@/i18n/nav';

interface Props {
  meta?: PostMeta;
}

const { meta: pageMeta } = Astro.props;

/* Derive locale from current URL via Astro's built-in i18n routing */
const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);

const nav = getNav(locale);

/* Compute SEO metadata and structured data based on page props */
const headMeta = getMeta(pageMeta, Astro.url, locale);
const schemaMarkup = getSchema(headMeta);
---

<!doctype html>
<html lang={locale}>
  <head>
    <Font cssVariable='--font-sans' />
    <Font cssVariable='--font-mono' />
    <SEO headMeta={headMeta} schemaMarkup={schemaMarkup} />
  </head>

  <body>
    <a href='#main-content' class='skip-link'>{t('skip.link')}</a>

    <header data-nosnippet>
      <Nav home={nav.home} links={nav.links} locale={locale} />
    </header>

    <main id='main-content'>
      <div class='limiter'>
        <slot />
      </div>
    </main>

    <footer data-nosnippet>
      <div class='limiter'>
        <Footer author={headMeta.author} year={new Date().getFullYear()} locale={locale} />
      </div>
    </footer>
  </body>
</html>
