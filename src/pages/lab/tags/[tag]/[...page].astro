---
/* Paginated list of posts filtered by a specific tag */
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { getAllTags, getPostsByTag } from '@/utils/posts';
import type { Page } from 'astro';
import type { Post } from '@/utils/posts';

export async function getStaticPaths({ paginate }: any) {
  const tags = await getAllTags();

  return (
    await Promise.all(
      tags.map(async (tag) => {
        const posts = await getPostsByTag(tag);
        return paginate(posts, { params: { tag }, pageSize: 10 });
      }),
    )
  ).flat();
}

interface Props {
  page: Page<Post>;
}

const { tag } = Astro.params;
const { page } = Astro.props;

/* Page-specific metadata for the selected tag and pagination state */
const pageMeta = {
  title: `Posts with tag "${tag}"${page.currentPage > 1 ? ` — Page ${page.currentPage}` : ''}`,
  description: `All articles tagged with ${tag}.`,
};
---

<Layout meta={pageMeta}>
  <header class='tag-header'>
    <h1>Tag: <span>#{tag}</span></h1>
    <p>{page.total} {page.total === 1 ? 'post' : 'posts'}</p>
    <a href='/lab/' class='back-link'>&larr; Back to Lab</a>
  </header>

  <ul class='post-list' role='list'>
    {
      page.data.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))
    }
  </ul>

  <Pagination
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    baseUrl={`/lab/tags/${tag}`}
  />
</Layout>

<style>
  .tag-header {
    margin-block-end: var(--space-xl);

    & h1 span {
      color: var(--color-primary);
      font-family: var(--font-mono);
    }

    & p {
      margin-block-start: var(--space-xs);
      font-size: var(--text-sm);
      opacity: 0.7;
    }
  }

  .back-link {
    display: inline-block;
    margin-block-start: var(--space-md);
    font-size: var(--text-sm);
    font-weight: 700;
    transition: opacity var(--transition-fast);

    &:hover {
      opacity: 0.7;
    }
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
</style>
