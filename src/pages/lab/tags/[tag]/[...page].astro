---
/* Paginated list of posts filtered by a specific tag */
import Layout from '@layouts/Layout.astro';
import PostList from '@components/PostList.astro';
import { getTagStaticPaths } from '@/utils/routes';
import { buildPostListTitle, buildPostListDescription } from '@/utils/titleBuilder';
import type { Page } from 'astro';
import type { PostEntry } from '@/utils/routes';
import type { PostMeta } from '@config/seo';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return await getTagStaticPaths(paginate);
}

interface Props {
  page: Page<PostEntry>;
}

const { tag } = Astro.params;
const { page } = Astro.props;

/* Page-specific metadata for the selected tag and pagination state */
const pageMeta: PostMeta = {
  title: buildPostListTitle(tag, page.currentPage > 1 ? page.currentPage : undefined),
  description: buildPostListDescription(tag),
};
---

<Layout meta={pageMeta}>
  <PostList
    tag={tag}
    posts={page.data}
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    baseUrl={`/lab/tags/${tag}`}
  />
</Layout>
