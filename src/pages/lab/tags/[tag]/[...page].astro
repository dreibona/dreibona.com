---
import Layout from '@layouts/Layout.astro';
import { formatDate } from '@/utils/date';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { Page } from 'astro';
import Pagination from '@components/Pagination.astro';

/**
 * Dynamic Routing & Pagination:
 * Generates paginated routes for every unique tag found in the published content collection.
 */
export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection('posts');

  // Privacy Filter: Ensures drafts and 'noindex' (robot: false) posts are excluded from public tag lists.
  const visiblePosts = allPosts.filter(
    (post: CollectionEntry<'posts'>) => !post.data.draft && post.data.robot !== false,
  );

  // Discovery: Extracts a flat array of unique tags from all visible posts.
  const uniqueTags = [
    ...new Set(visiblePosts.map((post: CollectionEntry<'posts'>) => post.data.tags || []).flat()),
  ];

  // Path Generation: Maps each tag to a set of paginated routes.
  return uniqueTags.flatMap((tag) => {
    const filteredPosts = visiblePosts.filter((post: CollectionEntry<'posts'>) =>
      post.data.tags?.includes(tag),
    );

    // Chronological Sort: Ensures newest content appears first within the tag index.
    const sortedPosts = filteredPosts.sort(
      (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
        b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
    );

    return paginate(sortedPosts, {
      params: { tag },
      pageSize: 10,
    });
  });
}

interface Props {
  page: Page<CollectionEntry<'posts'>>;
}

const { tag } = Astro.params;
const { page } = Astro.props;
const { data: posts } = page;

/**
 * Dynamic SEO:
 * Injects the current tag and page number into the title to prevent duplicate title issues across pages.
 */
const pageMeta = {
  title: `Posts tagged "${tag}" ${page.currentPage > 1 ? `— Page ${page.currentPage}` : ''}`,
  description: `Browse all articles tagged with ${tag}.`,
};
---

<Layout meta={pageMeta}>
  <div class='tag-header'>
    <h1>Tag: <span>#{tag}</span></h1>
    <p>Found {page.total} {page.total === 1 ? 'post' : 'posts'}</p>
    <a href='/lab/' class='back-link'>&larr; Back to Lab</a>
  </div>

  <ul class='post-list'>
    {
      posts.map((post) => {
        const date = formatDate(post.data.publishDate);
        return (
          <li>
            <article>
              <a href={`/lab/${post.id}/`}>
                <h2>{post.data.title}</h2>
              </a>
              <p>{post.data.description}</p>
              <p>
                Published: <time datetime={post.data.publishDate.toISOString()}>{date}</time>
              </p>
            </article>
          </li>
        );
      })
    }
  </ul>

  <Pagination
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    baseUrl={`/lab/tags/${tag}`}
  />
</Layout>

<style>
  .tag-header {
    margin-block-end: var(--space-xl);
  }

  .tag-header h1 span {
    color: var(--color-primary);
    font-family: var(--font-mono);
  }

  .back-link {
    display: inline-block;
    margin-block-start: var(--space-md);
    font-size: var(--text-sm);
    font-weight: 700;
    transition: opacity var(--transition-fast);
  }

  .back-link:hover {
    opacity: 0.7;
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  article h2 {
    margin-block-end: var(--space-xs);
  }

  article p {
    margin-block-end: var(--space-sm);
  }
</style>
