---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getMeta } from '@config/seo';
import { formatDate } from '@/utils/date';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import type { Page } from 'astro';
import Pagination from '@components/Pagination.astro';

/**
 * Generates static paths for the paginated Lab index.
 * Filters out drafts and sorts entries by publication date (newest first).
 */
export async function getStaticPaths({ paginate }: any) {
  const rawPosts = await getCollection('posts');

  // Privacy & Lifecycle: Exclude posts marked as drafts from production builds.
  const publishedPosts = rawPosts.filter((post: CollectionEntry<'posts'>) => !post.data.draft);

  const sortedPosts = publishedPosts.sort(
    (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
      b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
  );

  // Pagination: Injects 'page' prop into the component with the current subset of posts.
  return paginate(sortedPosts, { pageSize: 10 });
}

interface Props {
  page: Page<CollectionEntry<'posts'>>;
}

const { page } = Astro.props;
const { data } = page;

/**
 * Presentation Mapping:
 * Decorates raw collection data with SEO-ready titles and localized dates.
 * This ensures the list view utilizes the same metadata resolution logic as individual post pages.
 */
const allPosts = data.map((post: CollectionEntry<'posts'>) => ({
  ...getMeta(post.data, Astro.url),
  id: post.id,
  publishDate: formatDate(post.data.publishDate),
  originalImage: post.data.image,
}));
---

<Layout>
  <h1>Lab</h1>
  <ul>
    {
      allPosts.map((post) => (
        <li>
          <article>
            <a href={`/lab/${post.id}/`}>
              <h2>{post.title}</h2>
            </a>
            <p>{post.description}</p>
            <p>
              Published: <time datetime={post.publishDate}>{post.publishDate}</time>
            </p>
            {post.originalImage ? (
              <Image src={post.originalImage} alt={post.image.alt} />
            ) : (
              post.image && (
                <img src={post.image.url} alt={post.image.alt} loading='lazy' decoding='async' />
              )
            )}
          </article>
        </li>
      ))
    }
  </ul>

  <Pagination currentPage={page.currentPage} totalPages={page.lastPage} baseUrl='/lab' />
</Layout>

<style>
  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  article h2 {
    margin-bottom: var(--space-xs);
  }

  article p {
    margin-bottom: var(--space-sm);
  }
</style>
