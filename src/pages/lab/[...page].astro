---
/* Paginated list of all published blog posts in the Lab section */
import Layout from '@layouts/Layout.astro';
import PostList from '@components/PostList.astro';
import { getLabStaticPaths } from '@/utils/routes';
import type { Page } from 'astro';
import type { PostEntry } from '@/utils/routes';

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return await getLabStaticPaths(paginate);
}

interface Props {
  page: Page<PostEntry>;
}

const { page } = Astro.props;
---

<Layout>
  <PostList
    title='Lab'
    posts={page.data}
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    baseUrl='/lab'
  />
</Layout>
