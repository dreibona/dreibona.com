---
import Layout from '../../layouts/Layout.astro';
import { formatDate, getMeta } from '../../config/config';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((entry: CollectionEntry<'posts'>) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, author, image } = getMeta(entry.data, Astro.url);
const date = formatDate(entry.data.pubDate);
---

<Layout meta={entry.data}>
  <article>
    <h1>{title}</h1>
    <p>{author} — {date}</p>
    <img src={image.url} alt={image.alt} />
    <Content />
  </article>
</Layout>
