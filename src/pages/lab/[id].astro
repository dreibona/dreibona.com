---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import { formatDate, getMeta } from '@config/config';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'posts'>;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((entry: CollectionEntry<'posts'>) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, author } = getMeta(entry.data, Astro.url);
const date = formatDate(entry.data.pubDate);
---

<Layout meta={entry.data}>
  <article>
    <h1>{title}</h1>
    <p>{author} — {date}</p>
    {entry.data.image && <Image src={entry.data.image} alt={entry.data.imageAlt || title} />}
    <Content />
  </article>
</Layout>
