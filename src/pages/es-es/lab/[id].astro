---
/* Individual blog post page renderer — Spanish locale */
import Layout from '@layouts/Layout.astro';
import Post from '@components/Post.astro';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getReadingTime } from '@/utils/readingTime';
import { getPostDetailStaticPaths } from '@/utils/routes';
import { useTranslations } from '@/i18n/translations';
import type { Locale } from '@/i18n/locales';

export async function getStaticPaths() {
  return await getPostDetailStaticPaths('es-ES');
}

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = useTranslations(locale);
const readingTime = getReadingTime(entry.body ?? '', t('post.readingTime'));
---

<Layout meta={entry.data}>
  <Post meta={entry.data} readingTime={readingTime} variant='detail'>
    <Content />
  </Post>
</Layout>
